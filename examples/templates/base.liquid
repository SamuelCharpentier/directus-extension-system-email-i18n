<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content="Directus" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="robots" content="noindex,follow" />
    <title>{{ projectName }}</title>
    <style>
      body {
        margin: 0;
        background: #ffffff;
        color: #000000;
        font-family: Arial, Helvetica, sans-serif;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table {
        border-collapse: collapse;
      }

      img {
        border: 0;
        -ms-interpolation-mode: bicubic;
      }

      a[x-apple-data-detectors] {
        color: inherit !important;
        text-decoration: none !important;
        font-size: inherit !important;
        font-family: inherit !important;
        font-weight: inherit !important;
        line-height: inherit !important;
      }

      div[style*="margin: 16px 0;"] {
        margin: 0 !important;
      }

      .table-full {
        width: 100%;
        border-collapse: collapse;
      }

      .header-bar {
        background: #000000;
        padding: 20px 10px;
        text-align: center;
      }

      .header-bar a {
        display: inline-block;
      }

      .header-bar img {
        width: 120px;
        display: inline-block;
        border: 0;
      }

      .container {
        max-width: 680px;
        margin: 0 auto;
        padding: 24px 16px;
      }

      h1 {
        margin: 30px 0 5px 0;
        font-size: 24px;
        font-weight: 600;
        color: #000000;
      }

      p {
        margin: 0 0 12px 0;
        line-height: 1.5;
        font-size: 15px;
        color: #000000;
      }

      p a {
        color: #8f2dff;
      }

      .button-wrapper {
        text-align: center;
        margin: 30px 0;
      }

      .button {
        background-color: #8f2dff;
        border: 1px solid #8f2dff;
        border-radius: 6px;
        color: #ffffff;
        display: inline-block;
        font-weight: bold;
        line-height: normal;
        padding: 12px 18px;
        text-align: center;
        text-decoration: none;
        font-size: 20px;
      }

      .small-url {
        word-break: break-all;
        font-size: 12px;
        color: #666666;
      }

      .footer-note {
        margin: 50px 0 0 0;
        font-size: 12px;
        color: #666666;
        text-align: center;
      }

      .footer-bar {
        background: #000000;
        padding: 24px 10px;
        text-align: center;
        color: #ffffff;
      }

      .footer-bar h3 {
        margin: 0 0 8px 0;
        color: #ffffff;
        font-size: 16px;
      }

      .footer-bar p {
        margin: 0;
        font-size: 13px;
        color: #ffffff;
      }

      .footer-bar a {
        color: #ffffff;
        text-decoration: underline;
      }

      @media (max-width: 480px) {
        .container {
          padding: 16px;
        }

        .header-bar img {
          width: 100px;
        }

        h1 {
          font-size: 18px;
        }
      }
    </style>
  </head>
  <body>
    <table class="table-full" role="presentation" cellpadding="0" cellspacing="0">
      <tr>
        <td class="header-bar" align="center">
          {% if projectLogo != '' %}
          <a href="{{ projectUrl }}" target="_blank" rel="noopener">
            <img src="{{ projectLogo }}" alt="{{ projectName }}" />
          </a>
          {% endif %}
        </td>
      </tr>
      <tr>
        <td>
          <div class="container">
            {% block content %}{{ html }}{% endblock %}
            <p class="footer-note">{{ i18n.base.footer_note }}</p>
          </div>
        </td>
      </tr>
      <tr>
        <td class="footer-bar" align="center">
          <h3>{{ i18n.base.org_name }}</h3>
          <p>{{ i18n.base.org_address }}</p>
          <p>
            {% if projectUrl != '' %}
            <a href="{{ projectUrl }}" target="_blank" rel="noopener">{{ i18n.base.org_url }}</a>
            {% endif %}
          </p>
          {% block footer %}{% endblock %}
        </td>
      </tr>
    </table>
  </body>
</html>
