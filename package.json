{
	"name": "directus-extension-i18n-email",
	"version": "0.0.1",
	"description": "Directus CMS extension to translate emails (password reset, user registration and invitation)",
	"author": {
		"email": "scharpentier0@gmail.com",
		"name": "Samuel Charpentier"
	},
	"license": "MIT",
	"icon": "translate",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook",
		"i18n",
		"mail",
		"translation",
		"hook"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SamuelCharpentier/directus-extension-i18n-email.git"
	},
	"bugs": {
		"url": "https://github.com/SamuelCharpentier/directus-extension-i18n-email/issues"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"homepage": "https://github.com/SamuelCharpentier/directus-extension-i18n-email",
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "hook",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "11.17.2"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"verify": "npm run typecheck && npm run lint",
		"test": "npm run verify && vitest run",
		"test:only": "vitest run",
		"test:watch": "vitest",
		"build": "npm test && directus-extension build",
		"build:only": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.0.11",
		"@eslint/js": "^10.0.1",
		"@types/ip": "^1.1.3",
		"@types/node": "^25.4.0",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^10.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^4.1.4"
	}
}
